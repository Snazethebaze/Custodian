# Normalize text to LF in the repo; let git check out platform-native.
* text=auto eol=lf

# Source / text
*.lua  text eol=lf
*.toc  text eol=lf
*.md   text eol=lf
*.yml  text eol=lf
*.yaml text eol=lf
*.xml  text eol=lf
*.json text eol=lf
*.txt  text eol=lf

# Binary assets — never apply line-ending or other text filters (would corrupt them).
*.tga binary
*.blp binary
*.ttf binary
*.otf binary
*.ogg binary
*.mp3 binary
*.wav binary
*.png binary
*.jpg binary
